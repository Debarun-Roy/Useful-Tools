<?xml version="1.0" encoding="UTF-8"?>
<!--
  Tomcat Context configuration (Tomcat 11.0.21+).

  IMPORTANT FIX (April 2026):
  The attribute "sameSiteCookies" is not supported in Tomcat 11+ and is
  ignored (generates WARNING: "failed to set property [sameSiteCookies]").
  
  Solution: Use the SameSiteFilter servlet filter instead. This filter
  intercepts Set-Cookie response headers and appends "; SameSite=None" to
  them. This ensures JSESSIONID gets SameSite=None for cross-origin requests.
  
  SameSite=None is only valid with Secure=true. Web.xml already sets
  <secure>true</secure> for the session cookie, and Railway serves HTTPS,
  so the requirement is satisfied.
-->
<Context>
  <!-- Removed unsupported sameSiteCookies attribute (not recognized in Tomcat 11+) -->
</Context>