<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
           https://jakarta.ee/xml/ns/jakartaee/web-app_5_0.xsd"
         version="5.0">

  <display-name>UsefulTools</display-name>

  <welcome-file-list>
    <welcome-file>index.html</welcome-file>
  </welcome-file-list>

  <!-- ── Filter declarations ─────────────────────────────────────────────── -->

  <!--
    SameSiteFilter (April 2026): Fixes Tomcat 11 cross-origin cookie issue.
    The context.xml attribute "sameSiteCookies" is not supported in Tomcat 11+.
    This filter adds "; SameSite=None" to Set-Cookie response headers to enable
    JSESSIONID transmission on cross-origin requests (Vercel → Railway).
  -->
  <filter>
    <filter-name>SameSiteFilter</filter-name>
    <filter-class>common.filter.SameSiteFilter</filter-class>
  </filter>

  <filter>
    <filter-name>CorsFilter</filter-name>
    <filter-class>common.filter.CorsFilter</filter-class>
  </filter>

  <!--
    RateLimitFilter (Sprint 6): caps POST attempts per IP on auth endpoints.
    Max 10 POST requests per IP per 60-second window on /api/auth/*.
  -->
  <filter>
    <filter-name>RateLimitFilter</filter-name>
    <filter-class>common.filter.RateLimitFilter</filter-class>
  </filter>

  <filter>
    <filter-name>AuthFilter</filter-name>
    <filter-class>common.filter.AuthFilter</filter-class>
  </filter>

  <!--
    CsrfFilter (Sprint 6): double-submit cookie CSRF protection.
    Validates X-XSRF-TOKEN header against the session csrfToken attribute
    for all non-safe, non-public HTTP requests.
    Placed AFTER AuthFilter so unauthenticated requests are already rejected.
  -->
  <filter>
    <filter-name>CsrfFilter</filter-name>
    <filter-class>common.filter.CsrfFilter</filter-class>
  </filter>

  <!-- ── Filter mappings (ORDER MATTERS — top to bottom) ─────────────────── -->

  <!-- 0. SameSite runs first on ALL requests to add SameSite=None to cookies. -->
  <filter-mapping>
    <filter-name>SameSiteFilter</filter-name>
    <url-pattern>/*</url-pattern>
    <dispatcher>REQUEST</dispatcher>
  </filter-mapping>

  <!-- 1. CORS runs second on every request. -->
  <filter-mapping>
    <filter-name>CorsFilter</filter-name>
    <url-pattern>/*</url-pattern>
    <dispatcher>REQUEST</dispatcher>
  </filter-mapping>

  <!-- 2. Rate limit runs third, only on auth endpoints. -->
  <filter-mapping>
    <filter-name>RateLimitFilter</filter-name>
    <url-pattern>/api/auth/*</url-pattern>
    <dispatcher>REQUEST</dispatcher>
  </filter-mapping>

  <!-- 3. Auth runs fourth on all API endpoints. -->
  <filter-mapping>
    <filter-name>AuthFilter</filter-name>
    <url-pattern>/api/*</url-pattern>
    <dispatcher>REQUEST</dispatcher>
  </filter-mapping>

  <!-- 4. CSRF runs last on all API endpoints (after Auth rejects unauth). -->
  <filter-mapping>
    <filter-name>CsrfFilter</filter-name>
    <url-pattern>/api/*</url-pattern>
    <dispatcher>REQUEST</dispatcher>
  </filter-mapping>

  <session-config>
    <!-- Session timeout set to 60 minutes of inactivity.
         This ensures sufficient time for legitimate user activities like
         calculations, but prevents indefinitely stale sessions.
         
         IMPORTANT: In cross-origin deployments (Vercel → Railway), the
         JSESSIONID cookie must have SameSite=None to be sent on 
         cross-origin requests. This is now handled by SameSiteFilter
         (which adds "; SameSite=None" to all Set-Cookie headers).
         Tomcat 11 doesn't support the context.xml sameSiteCookies attribute.
    -->
    <session-timeout>60</session-timeout>
    <cookie-config>
      <http-only>true</http-only>
      <secure>true</secure>
      <!-- SameSite attribute is set by SameSiteFilter (April 2026 fix),
           not by context.xml. This ensures JSESSIONID and XSRF-TOKEN
           both have SameSite=None for cross-origin support.
      -->
    </cookie-config>
  </session-config>

</web-app>