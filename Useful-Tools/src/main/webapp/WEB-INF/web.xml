<?xml version="1.0" encoding="UTF-8"?>
<!--
    NAMESPACE NOTE
    ══════════════
    The Eclipse-generated version of this file used:
        version="2.4" xmlns="http://java.sun.com/xml/ns/j2ee"
    That is the Servlet 2.4 / J2EE 1.4 specification from 2003.

    Every servlet and filter in this project uses:
        import jakarta.servlet.*;
    The jakarta.* package prefix only exists from Jakarta EE 9 onwards,
    which corresponds to Servlet 5.0 and Tomcat 10+. The web.xml namespace
    must match — otherwise the deployment descriptor contradicts the runtime.

    The correct namespace for this project is therefore:
        version="5.0" xmlns="https://jakarta.ee/xml/ns/jakartaee"

    Tomcat 10+ will parse both, but declaring 2.4 while running 5.0 is
    technically incorrect and disallows the use of modern schema features.
    If strict schema validation is ever enabled, the old namespace fails.
-->
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="https://jakarta.ee/xml/ns/jakartaee" xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_5_0.xsd" version="5.0">
  <display-name>UsefulTools</display-name>
  <welcome-file-list>
    <welcome-file>index.html</welcome-file>
  </welcome-file-list>
  <filter>
    <filter-name>CorsFilter</filter-name>
    <filter-class>common.filter.CorsFilter</filter-class>
  </filter>
  <filter-mapping>
    <filter-name>CorsFilter</filter-name>
    <url-pattern>/*</url-pattern>
    <dispatcher>REQUEST</dispatcher>
  </filter-mapping>
  <filter>
    <filter-name>AuthFilter</filter-name>
    <filter-class>common.filter.AuthFilter</filter-class>
  </filter>
  <filter-mapping>
    <filter-name>AuthFilter</filter-name>
    <url-pattern>/api/*</url-pattern>
    <dispatcher>REQUEST</dispatcher>
  </filter-mapping>
</web-app>